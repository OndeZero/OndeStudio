# OndeStudio environment — template
# Copy to .env and fill in the real values. .env is gitignored; NEVER commit it.

# ── AzuraCast ────────────────────────────────────────────────
AZURACAST_BASE_URL=https://studio.ondezero.net
# API key (AzuraCast: My Account -> API Keys). See docs for required permissions.
AZURACAST_API_KEY=
# Station shortcodes
AZURACAST_STATION_MAIN=oz
AZURACAST_STATION_TEST=wz-test

# ── OndeStudio (all optional, defaults shown) ────────────────
# PORT=4400
# HOST=127.0.0.1
# DB_PATH=data/ondestudio.sqlite
# LOG_LEVEL=info
# NOW_POLL_SECONDS=10
# STATION_TZ=Europe/Paris
